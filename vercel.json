  "framework": "nextjs",
  "installCommand": "npm --prefix paygent-frontend install",
  "buildCommand": "npm --prefix paygent-frontend run build",
  "outputDirectory": "paygent-frontend/.next",
  "env": {
    "NEXT_PUBLIC_API_URL": "@api_url",
    "NEXT_PUBLIC_OPENCLAW_URL": "@openclaw_url"
  }
}
